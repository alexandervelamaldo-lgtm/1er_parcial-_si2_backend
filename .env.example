# ── PayPal ────────────────────────────────────────────────────────────────────
# Obtén tus credenciales sandbox en https://developer.paypal.com/developer/applications
# Cambia PAYPAL_MODE=live y usa credenciales de producción antes de ir a producción.
# NUNCA expongas PAYPAL_CLIENT_SECRET al cliente móvil.
PAYPAL_CLIENT_ID=tu-paypal-client-id-sandbox
PAYPAL_CLIENT_SECRET=tu-paypal-client-secret-sandbox
PAYPAL_MODE=sandbox
# Webhook ID (opcional para sandbox — requerido en producción para verificar firmas)
# Configúralo en https://developer.paypal.com/developer/webhooks  →  copiar el Webhook ID
PAYPAL_WEBHOOK_ID=
# Moneda ISO 4217. PayPal sandbox usa USD. Ajusta según la cuenta de producción.
PAYPAL_CURRENCY=USD

